# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# Disable directory listing
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>

# Block direct web access to setup/migration/cron scripts (use CLI or cron token)
<FilesMatch "^(install-db|migrate-.*|seed-blog|cron-sync|cron-verify-deposits)\.php$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# SMM Turk - Clean URLs (no .php in browser) + API rewrite
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /
# Real files and directories: do not rewrite
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
# API and referral
RewriteRule ^api/v2$ api/v2.php [L,QSA]
RewriteRule ^c/([a-zA-Z0-9_-]+)/?$ c.php?ref=$1 [L,QSA]
# Sitemap & robots
RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^robots\.txt$ robots.php [L]
# Blog: /blog -> blog.php, /blog/slug -> blog-post.php?slug=slug
RewriteRule ^blog/?$ blog.php [L,QSA]
RewriteRule ^blog/([a-zA-Z0-9\-]+)/?$ blog-post.php?slug=$1 [L,QSA]
# Clean URLs: / -> index.php, /page -> page.php, /admin -> admin/index.php, /admin/xxx -> admin/xxx.php
RewriteRule ^$ index.php [L,QSA]
RewriteRule ^admin/?$ admin/index.php [L,QSA]
RewriteRule ^admin/([a-zA-Z0-9_.-]+)/?$ admin/$1.php [L,QSA]
RewriteRule ^([a-zA-Z0-9_.-]+)/?$ $1.php [L,QSA]
</IfModule>
